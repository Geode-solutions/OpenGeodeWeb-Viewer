{
  "rpc": "attribute_name",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "block_ids": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "field_type": {
      "type": "string",
      "enum": ["points", "cells"]
    }
  },
  "required": ["id", "block_ids", "name", "field_type"],
  "additionalProperties": false
}
